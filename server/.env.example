# Server environment. Copy to `.env` (or export on the VPS) — do NOT commit real values.
# Every var has a safe default in src/config.ts; all are optional.

# HTTP + WebSocket port.
PORT=3004

# PostgreSQL connection string for persisting finished results / leaderboard.
# Leave EMPTY to disable persistence entirely (the game still runs normally).
# Example: postgres://user:password@127.0.0.1:5432/typingrace
DATABASE_URL=

# How long (ms) a dropped player's seat + progress is held for reconnect.
RECONNECT_GRACE_MS=30000

# CORS allow-list for Socket.IO. '*' for dev; in prod the client is same-origin so this
# can stay '*' or be tightened to https://race.aiklaotrip.com.
CORS_ORIGIN=*
