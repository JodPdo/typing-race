# Client environment (Vite). Copy to `.env` for local overrides — do NOT commit `.env`.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Base URL of the Socket.IO / API server.
# - Local dev: leave unset; the client falls back to http://localhost:3004.
# - Production: set at BUILD time so the static bundle targets the prod origin.
#   (CI sets this to https://race.aiklaotrip.com — see .github/workflows/deploy.yml)
VITE_SERVER_URL=http://localhost:3004
